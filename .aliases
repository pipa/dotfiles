# ===========================================
# System Aliases
# ===========================================

# System monitor
alias top='btop'
alias htop='btop'

# Quick help
alias cheat='tldr'

# Create directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract any archive
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2) tar xjf "$1" ;;
            *.tar.gz) tar xzf "$1" ;;
            *.bz2) bunzip2 "$1" ;;
            *.rar) unrar x "$1" ;;
            *.gz) gunzip "$1" ;;
            *.tar) tar xf "$1" ;;
            *.tbz2) tar xjf "$1" ;;
            *.tgz) tar xzf "$1" ;;
            *.zip) unzip "$1" ;;
            *.Z) uncompress "$1" ;;
            *.7z) 7z x "$1" ;;
            *) echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Kill process on port
killport() {
    lsof -ti:$1 | xargs kill -9 2>/dev/null || echo "No process on port $1"
}

# Find process
psg() {
    ps aux | grep -v grep | grep -i -e "$@"
}

# Weather
weather() {
    curl -s "wttr.in/${1:-}"
}

# IP Address
myip() {
    curl -s https://api.ipify.org && echo
}

# Count lines of code
cloc() {
    find . -type f \( -name "*.js" -o -name "*.ts" -o -name "*.jsx" -o -name "*.tsx" -o -name "*.py" -o -name "*.rb" -o -name "*.go" -o -name "*.rs" -o -name "*.java" -o -name "*.c" -o -name "*.cpp" -o -name "*.h" -o -name "*.hpp" \) | xargs wc -l 2>/dev/null | tail -1
}

# ===========================================
# Network & SSH
# ===========================================

# SSH with key
sshkey() {
    ssh -i ~/.ssh/"$1" "$2"
}

# ===========================================
# Project-Specific Shortcuts
# ===========================================

# Dev folder shortcuts
alias dev='cd ~/Developer'
alias dl='cd ~/Developer/labs'
alias dw='cd ~/Developer/work'

# ===========================================
# Functions
# ===========================================

# Create a new project folder
newproject() {
    mkdir -p "$1" && cd "$1"
    if command -v git &> /dev/null; then
        git init
    fi
}

# Quick commit with message
commitmsg() {
    git add -A && git commit -m "$1"
}

# Undo last commit but keep changes
git-undo() {
    git reset --soft HEAD~1
}

# Show git diff with colors
gdiff() {
    git diff --color-words "$@"
}

# Create git branch and switch to it
create-branch() {
    git checkout -b "$1"
}

# Delete merged branches
gbclean() {
    git branch --merged main | grep -v "main" | xargs -n 1 git branch -d
}

