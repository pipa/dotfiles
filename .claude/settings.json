{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod 777 *)",
      "Bash(> /dev/sda*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(:(){ :|:& };:)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(init 0)",
      "Bash(init 6)",
      "Bash(systemctl poweroff*)",
      "Bash(systemctl reboot*)",
      "Bash(kill -9 1)",
      "Bash(killall *)",
      "Bash(pkill -9 *)",
      "Bash(iptables -F*)",
      "Bash(ufw disable*)",
      "Bash(passwd *)",
      "Bash(chown -R *)",
      "Bash(userdel *)",
      "Bash(deluser *)",
      "Bash(visudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(npm publish*)",
      "Bash(docker rm -f $(docker ps -aq)*)",
      "Bash(docker system prune -af*)",
      "Read(//etc/shadow)",
      "Read(//etc/gshadow)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/*_key)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.docker/config.json)",
      "Edit(/.env)",
      "Edit(/.env.*)",
      "Edit(~/.ssh/**)",
      "Write(/.env)",
      "Write(/.env.*)",
      "Write(~/.ssh/**)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git remote -v*)",
      "Bash(npm run *)",
      "Bash(npm test*)",
      "Bash(pnpm run *)",
      "Bash(pnpm test*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm build*)",
      "Bash(pnpm lint*)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(date*)",
      "Bash(uname *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs *)"
    ]
  }
}
