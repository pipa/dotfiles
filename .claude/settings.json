      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(docker *)",
      "Bash(docker compose *)",
      "Bash(lazygit *)",
      "Bash(claude *)",
      "Bash(doppler *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(python *)",
      "Bash(python3 *)",
