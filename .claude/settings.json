      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(fnm *)",
      "Bash(nvim *)",
      "Bash(vim *)",
      "Bash(eza *)",
      "Bash(bat *)",
      "Bash(fd *)",
      "Bash(fzf *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(whoami *)",
      "Bash(pwd *)",
