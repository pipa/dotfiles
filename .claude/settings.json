      "Bash(pip3 *)",
      "Bash(brew *)",
      "Read(**)",
      "Edit(**)",
      "Glob(**)",
      "WebFetch"
    ],
    "deny": [
      "Bash(sudo rm -rf /*)",
      "Bash(sudo rm -rf /)",
      "Bash(sudo rm -rf /home)",
      "Bash(sudo rm -rf /usr)",
      "Bash(sudo rm -rf /opt)",
      "Bash(sudo rm -rf /var)",
      "Bash(mkfs.*)",
      "Bash(dd if=*)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(drop *)",
      "Bash(truncate -s 0 *)",
      "Bash(shred *)",
      "Bash(chmod 777 *)",
      "Bash(chown -R root:root *)",
      "Bash(mkdir -p /etc/cron.d *)",
      "Bash(crontab -r *)",
      "Bash(sudo su -)",
      "Bash(sudo -i)",
      "Bash(sudo passwd *)",
      "Bash(useradd *)",
      "Bash(usermod *)",
      "Bash(deluser *)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials.json)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*-secret*)",
      "Read(./**/*-token*)",
      "Read(./**/*password*)",
      "Read(./**/.aws/credentials)",
      "Read(./**/.aws/config)",
      "Read(./**/.ssh/id_*)"
